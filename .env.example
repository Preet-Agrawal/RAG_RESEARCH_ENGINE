# Groq API Key (FREE - get it from https://console.groq.com)
GROQ_API_KEY=

# Google Gemini API Key (FREE - get it from https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# OpenAI API Key (paid - optional)
OPENAI_API_KEY=

# Anthropic API Key (paid - optional)
ANTHROPIC_API_KEY=

# Express proxy → FastAPI backend
FASTAPI_URL=http://localhost:8000

# Model Configuration
DEFAULT_MODEL=llama-3.1-8b-instant
EMBEDDING_MODEL=text-embedding-3-small

# Experiment Configuration
RESULTS_DIR=./results
DATA_DIR=./data
CACHE_DIR=./.cache
